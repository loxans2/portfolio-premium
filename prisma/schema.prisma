generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  USER
  CONTRIBUTOR
  MODERATOR
  ADMIN
}

enum Plan {
  FREE
  PREMIUM
  VIP
}

enum ResourceCategory {
  GAMES
  MOVIES
  PLUGINS
  SOFTWARE
  FASHION
  MUSIC
  EBOOKS
  TEMPLATES
  OTHER
}

enum ResourceStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

enum ResourceAccess {
  FREE
  PREMIUM
  VIP
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
  PAST_DUE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ============================================================
// AUTH / USERS
// ============================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String?
  name          String?
  avatar        String?
  provider      String?  // 'credentials' | 'google' | 'github'
  providerId    String?
  role          Role     @default(USER)
  plan          Plan     @default(FREE)
  bio           String?  @db.Text
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  resources     Resource[]     @relation("ResourceAuthor")
  favorites     Favorite[]
  downloads     Download[]
  comments      Comment[]
  reports       Report[]
  subscriptions Subscription[]
  payments      Payment[]

  @@index([role])
  @@index([plan])
}

// ============================================================
// RESOURCES (cœur de la plateforme)
// ============================================================

model Resource {
  id          String           @id @default(cuid())
  slug        String           @unique
  title       String
  category    ResourceCategory @default(OTHER)
  excerpt     String
  description String           @db.Text
  coverImage  String
  images      String[]         @default([])
  fileUrl     String?
  fileSize    String?
  version     String?
  license     String?
  status      ResourceStatus   @default(PUBLISHED)
  access      ResourceAccess   @default(FREE)
  price       Float?           @default(0)
  tags        String[]         @default([])
  featured    Boolean          @default(false)
  views       Int              @default(0)
  downloads   Int              @default(0)
  ratingAvg   Float            @default(0)
  ratingCount Int              @default(0)
  order       Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  authorId    String?
  author      User?            @relation("ResourceAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  favorites   Favorite[]
  downloadLogs Download[]
  comments    Comment[]
  reports     Report[]

  @@index([category])
  @@index([status, featured])
  @@index([access])
  @@index([slug])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
  @@index([resourceId])
}

model Download {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resourceId])
  @@index([createdAt])
}

model Comment {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  body       String   @db.Text
  rating     Int      @default(0)
  approved   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, approved])
  @@index([userId])
}

model Report {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  reason     String
  details    String?  @db.Text
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resolved])
  @@index([resourceId])
}

// ============================================================
// SUBSCRIPTIONS & PAYMENTS
// ============================================================

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  plan               Plan
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  stripeSubId        String?            @unique
  stripeCustomerId   String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments           Payment[]

  @@index([userId])
  @@index([status])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  subscriptionId  String?
  amount          Float
  currency        String        @default("EUR")
  status          PaymentStatus @default(PENDING)
  description     String?
  stripePaymentId String?       @unique
  createdAt       DateTime      @default(now())

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================
// SITE CONTENT (conservé du portfolio)
// ============================================================

model Settings {
  id           String   @id @default("singleton")
  siteName     String   @default("ResourceHub")
  tagline      String   @default("Le hub premium de ressources créatives.")
  bio          String   @db.Text
  email        String   @default("")
  phone        String?
  location     String?
  instagram    String?
  linkedin     String?
  github       String?
  behance      String?
  heroTitle    String   @default("Toutes vos ressources premium, au même endroit.")
  heroSubtitle String   @default("Jeux, films, plugins, logiciels et plus encore. Créés par nous, libres de droits, accessibles aux abonnés.")
  aboutTitle   String   @default("À propos")
  aboutBody    String   @db.Text
  updatedAt    DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  body      String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProcessStep {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  icon        String   @default("Sparkles")
  duration    String?
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PricingPlan {
  id          String   @id @default(cuid())
  name        String
  price       String
  priceSuffix String?  @default("")
  description String
  features    String[] @default([])
  cta         String   @default("S'abonner")
  ctaUrl      String   @default("/auth/register")
  highlighted Boolean  @default(false)
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Stat {
  id        String   @id @default(cuid())
  label     String
  value     Int
  suffix    String?  @default("")
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  content   String   @db.Text
  image     String?
  rating    Int      @default(5)
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String   @default("Sparkles")
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
