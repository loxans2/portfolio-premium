# =============================================================
# CORE — requis pour démarrer
# =============================================================

# PostgreSQL (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Admin seeded (créé au seed)
ADMIN_EMAIL="echemereau@gmail.com"
ADMIN_PASSWORD="change-me-strong-password"

# URL secrète pour atteindre /admin (double verrou)
ADMIN_SECRET="ma-route-secrete-rare"

# =============================================================
# CLOUDINARY — uploads images & téléchargements signés
# =============================================================

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# =============================================================
# STRIPE — abonnements Premium / VIP (facultatif au démarrage)
# =============================================================
# Sans ces variables, les boutons /pricing montreront une erreur "Stripe non configuré"
# mais le site fonctionne en mode "FREE only".

STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Crée 2 prix récurrents dans le dashboard Stripe (9.99€/mois, 24.99€/mois)
STRIPE_PRICE_PREMIUM="price_..."
STRIPE_PRICE_VIP="price_..."

# =============================================================
# OAuth — facultatif (login social)
# =============================================================
# Sans ces variables, seul le login email/password est actif.

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
